    "express-session": "^1.18.1",
    "fflate": "^0.8.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "postcss": "^8.5.14",
    "prom-client": "^15.1.3",
    "resend": "^4.8.0",
    "stripe": "^17.4.0",
    "tailwindcss": "^3.4.19",
    "tar-stream": "^2.2.0",
