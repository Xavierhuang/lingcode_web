PORT=3000

# Site origin (no trailing slash). Must match the URL users open in the browser so /oauth/web-callback matches.
PUBLIC_ORIGIN=https://lingcode.dev

# Local: NODE_ENV=development (session cookie works on http://127.0.0.1)
# Production: NODE_ENV=production behind HTTPS
NODE_ENV=development

# One of: plain password (dev only) OR bcrypt hash (recommended for production)
ADMIN_PASSWORD=admin123
# ADMIN_PASSWORD_HASH=$2b$10$...

SESSION_SECRET=e2d39305f25e58ff0845f459d36f82bfe7cbaf02a75e1c763ffa9c28f30e693b

# Optional: if users hit both https://lingcode.dev and https://www.lingcode.dev, set e.g. .lingcode.dev so the session cookie is shared (then restart lingcode-api).
# SESSION_COOKIE_DOMAIN=.lingcode.dev

# Resend (https://resend.com) — password reset: POST /api/account/forgot-password, pages forgot-password.html / reset-password.html
RESEND_API_KEY=re_JWCBMUR6_PKGaGAiBq54ac6PWzadA6P5T
# Default sender for Resend trials; verify your domain in Resend and use e.g. noreply@yourdomain.com
RESEND_FROM=hhuangweijia@gmail.com
# Optional: local one-off test — node mail test script / manual send
RESEND_TEST_TO=huangxavier526@gmail.com


# Optional: POST /api/register uses header X-API-Key: <value>. JSON body may include password (min 8 chars) to set account password_hash.
REGISTER_API_KEY=

# --- Stripe (Cursor-style: Free + Pro monthly + Pro annual) ---
# Dashboard: https://dashboard.stripe.com — create Product "LingCode Pro", add monthly + annual Prices, enable Customer Portal (Settings → Billing → Customer portal).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (recurring) for Pro:
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
# Price IDs (recurring) for Max Pro — REQUIRED so paid Max Pro subs map to tier 'max_pro'
# (without these, the webhook safely falls back to 'pro' and Max Pro buyers get Pro limits).
STRIPE_PRICE_MAX_PRO_MONTHLY=
STRIPE_PRICE_MAX_PRO_ANNUAL=
# Storage add-on (Model B — à-la-carte storage blocks). Create a recurring, PER-UNIT
# Stripe price (metered or licensed-with-quantity) and put its ID here; each purchased
# unit grants STORAGE_ADDON_BLOCK_BYTES on top of the tier's maxStorageBytes. Leave the
# price ID blank to keep the add-on disabled (purchased storage stays 0).
STRIPE_PRICE_STORAGE_ADDON=
STORAGE_ADDON_BLOCK_BYTES=107374182400   # 100 GB per unit
# Webhook endpoint URL: https://YOUR_DOMAIN/api/stripe/webhook
# Subscribe to: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, customer.deleted

# LingModel: owner-funded managed proxy (users without BYOK; 100 free prompts per account unless Pro). Required for LingModel.
# The route speaks Anthropic message-format; the server forwards to the upstream's `/anthropic` compatibility endpoint.
# Default upstream is Moonshot Kimi (api.moonshot.ai) — provide a Moonshot key. No DeepSeek key required.
MOONSHOT_API_KEY=
# Alt upstream: DeepSeek. To use it, set DEEPSEEK_API_KEY and point the URL at DeepSeek (see LINGMODEL_ANTHROPIC_MESSAGES_URL below).
DEEPSEEK_API_KEY=
# Override the upstream endpoint + key explicitly (DB app_config takes precedence over both in prod):
# LINGMODEL_ANTHROPIC_MESSAGES_URL=https://api.moonshot.ai/anthropic/v1/messages
# LINGMODEL_UPSTREAM_API_KEY=
# Optional override (default 100) — LingModel free tier lifetime cap
HOSTED_PROMPT_LIMIT=100
# Pro: max LingModel prompts per UTC day on your hosted key (default 500). Set to 0 to disable daily cap.
LINGMODEL_PRO_DAILY_PROMPT_LIMIT=500
#
# --- Model ids (sent to the upstream /anthropic/v1/messages) ---
#   Moonshot Kimi → kimi-k2.6   (default for LingModel "auto" if LINGMODEL_DEFAULT_MODEL unset)
#   DeepSeek alt  → deepseek-v4-flash / deepseek-v4-pro   (only when routing to DeepSeek)
# DeepSeek legacy aliases `deepseek-chat` / `deepseek-reasoner` still route to V4-Flash but are slated for retirement.
#
# Recommended LingModel allow-list + default. Comment out both to rely only on server code default (kimi-k2.6).
LINGMODEL_ALLOWED_MODELS=kimi-k2.6
LINGMODEL_DEFAULT_MODEL=kimi-k2.6
#
# Optional stricter controls:
# LINGMODEL_FORCE_MODEL=kimi-k2.6
#   Every request uses this model (ignores app picker and ALLOWED).
# LINGMODEL_FREE_TIER_MODEL=kimi-k2.6
#   Non-Pro users only; ignored if LINGMODEL_FORCE_MODEL is set. Set a premium id via LINGMODEL_DEFAULT_MODEL for Pro tier.
# Max output tokens per request (always enforced; Pro is not unlimited):
# LINGMODEL_MAX_OUTPUT_TOKENS_FREE=4096   (default if unset)
# LINGMODEL_MAX_OUTPUT_TOKENS_PRO=8192    (default if unset)
# LINGMODEL_MAX_OUTPUT_TOKENS=8192        (optional: single cap for both tiers if per-tier vars unset)

# --- Database ---
# No separate migrate step. On first request, SQLite creates:
#   website/server/data.db
# and the users table. Delete data.db to reset.

# ---- Phase 4: secrets vault ------------------------------------------
# Master key for AES-256-GCM at-rest encryption of user-pasted secrets
# (Stripe API keys, etc.) stored in the prototype_secrets table.
#
# Required for: 🔐 Secrets dialog in /try, + Add Stripe checkout flow.
# All routes return 503 until this is set.
#
# Generate with:
#   openssl rand -hex 32
#
# WARNING: Losing this key bricks every prototype_secrets row encrypted
# under it (decrypt fails with auth-tag mismatch). Back it up somewhere
# durable (1Password, vault) before deploying.
#
# Old name LINGCODE_SECRETS_KEY is still honored as a fallback for
# environments deployed before the rename.
LINGCODE_VAULT_MASTER_KEY=

# --- Object storage: DigitalOcean Spaces (LingCode Cloud file storage) ---
# When set, managed-backend file uploads go to Spaces (a separate, CDN-backed
# object store) instead of base64 in the SQLite control-plane DB — keeping
# data.db small on the droplet. Leave unset to fall back to inline base64.
# Create a Space + (optional) CDN endpoint in the DO console, then:
#   SPACES_ENDPOINT — region origin, e.g. https://nyc3.digitaloceanspaces.com
#   SPACES_REGION   — e.g. nyc3
#   SPACES_BUCKET   — the Space name
#   SPACES_KEY / SPACES_SECRET — a Spaces access keypair
#   SPACES_CDN_BASE — optional CDN origin for public reads, e.g. https://cdn.lingcode.dev
SPACES_ENDPOINT=
SPACES_REGION=
SPACES_BUCKET=
SPACES_KEY=
SPACES_SECRET=
SPACES_CDN_BASE=
