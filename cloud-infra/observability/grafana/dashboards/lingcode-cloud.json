{
  "uid": "lingcode-cloud",
  "title": "LingCode Cloud",
  "tags": ["lingcode"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "API request rate by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(lingcode_http_requests_total[5m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 2, "type": "timeseries", "title": "API latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(lingcode_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "PG pool (total / idle / waiting)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "lingcode_cloud_pg_pool_total", "legendFormat": "total" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "lingcode_cloud_pg_pool_idle", "legendFormat": "idle" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "lingcode_cloud_pg_pool_waiting", "legendFormat": "waiting" }
      ]
    },
    {
      "id": 4, "type": "timeseries", "title": "PgBouncer clients waiting",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pgbouncer_pools_client_waiting_connections)", "legendFormat": "waiting" }
      ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Replication slot retained WAL (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "pg_replication_slot_retained_retained_bytes", "legendFormat": "{{slot_name}}" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Cloud query p95 by op (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(lingcode_cloud_query_duration_seconds_bucket[5m])) by (le, op))", "legendFormat": "{{op}}" }
      ]
    },
    {
      "id": 7, "type": "stat", "title": "Min disk free %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.15 }, { "color": "green", "value": 0.3 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "min(node_filesystem_avail_bytes{fstype=~\"ext4|xfs\"} / node_filesystem_size_bytes{fstype=~\"ext4|xfs\"})", "legendFormat": "free" }
      ]
    },
    {
      "id": 8, "type": "stat", "title": "Connections vs max",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.8 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_stat_database_numbackends) / on() pg_settings_max_connections", "legendFormat": "used" }
      ]
    }
  ]
}
