# alertmanager.yml — COPY to alertmanager.yml and set the webhook URL
# (bootstrap-monitoring.sh renders it from ALERT_WEBHOOK in .env). The rendered
# file is gitignored.
#
# ALERT_WEBHOOK is the SAME Slack/Discord incoming webhook the cron scripts use,
# so all alerts land in one channel. slack_configs posts the Slack/Discord
# incoming-webhook shape. Discord users: append `/slack` to the Discord webhook
# URL so it accepts the Slack payload format.

route:
  receiver: webhook
  group_by: ['alertname']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 3h

receivers:
  - name: webhook
    slack_configs:
      - api_url: '__ALERT_WEBHOOK__'
        channel: '#alerts'
        send_resolved: true
        title: '{{ .CommonLabels.severity | toUpper }}: {{ .CommonAnnotations.summary }}'
        text: >-
          {{ range .Alerts }}{{ .Annotations.description }}
          {{ end }}
