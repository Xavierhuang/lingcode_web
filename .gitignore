# Dependencies
node_modules/

# Secrets — never publish (keep .env.example as the template)
.env
.env.*
!.env.example

# Local databases / dumps (contain user tokens, app_config, vault ciphertext)
*.db
*.sqlite
*.sqlite3
*.dump

# Large binaries / release artifacts — distributed via lingcode.dev, not source
*.dmg
*.zip
*.pkg
*.tar.gz

# OS / editor cruft
.DS_Store
*.log
