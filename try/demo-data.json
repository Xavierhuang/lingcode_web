            "</head><body>",
            "<div id=\"score\">Score: 0</div>",
            "<canvas id=\"c\" width=\"400\" height=\"400\"></canvas>",
            "<div id=\"over\">Game Over · Refresh to retry</div>",
            "<script>",
            "const c = document.getElementById('c'), x = c.getContext('2d'), G = 20;",
            "let snake = [{x:10,y:10}], dir = {x:1,y:0}, food = {x:5,y:5}, score = 0, dead = false;",
            "function place() { food = { x: Math.floor(Math.random()*G), y: Math.floor(Math.random()*G) }; }",
            "function tick() {",
            "  if (dead) return;",
            "  const h = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };",
            "  if (h.x<0 || h.x>=G || h.y<0 || h.y>=G || snake.some(s => s.x===h.x && s.y===h.y)) {",
