        "claude": {
          "ttftMs": 620,
          "totalMs": 9400,
          "inputTokens": 320,
          "outputTokens": 2080,
          "text": [
            "I'll build a clean Snake game with the requested features. Here's the complete single-file implementation:",
            "",
            "```html",
            "<!DOCTYPE html>",
            "<html lang=\"en\">",
            "<head>",
            "  <meta charset=\"utf-8\">",
            "  <title>Snake</title>",
            "  <style>",
            "    * { box-sizing: border-box; }",
            "    body {",
            "      margin: 0;",
            "      background: #0b0b0e;",
            "      display: flex;",
            "      align-items: center;",
            "      justify-content: center;",
            "      height: 100vh;",
            "      font-family: system-ui, -apple-system, sans-serif;",
            "    }",
            "    canvas {",
            "      background: #1a1a22;",
            "      border-radius: 12px;",
            "      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);",
            "    }",
            "    #score {",
            "      position: fixed;",
            "      top: 20px;",
            "      left: 20px;",
            "      color: #fff;",
            "      font-weight: 600;",
            "      font-size: 20px;",
            "      letter-spacing: 0.02em;",
            "    }",
            "    #over {",
            "      position: fixed;",
            "      inset: 0;",
            "      display: none;",
            "      align-items: center;",
            "      justify-content: center;",
            "      background: rgba(0, 0, 0, 0.78);",
            "      color: #fff;",
            "      font-weight: 700;",
            "      font-size: 32px;",
            "      backdrop-filter: blur(4px);",
            "    }",
            "  </style>",
            "</head>",
            "<body>",
            "  <div id=\"score\">Score: 0</div>",
            "  <canvas id=\"canvas\" width=\"400\" height=\"400\"></canvas>",
            "  <div id=\"over\">Game Over · Refresh to retry</div>",
            "  <script>",
            "    const canvas = document.getElementById('canvas');",
            "    const ctx = canvas.getContext('2d');",
            "    const scoreEl = document.getElementById('score');",
            "    const overEl = document.getElementById('over');",
            "    const GRID = 20, CELL = 20;",
            "",
            "    let snake = [{ x: 10, y: 10 }];",
            "    let direction = { x: 1, y: 0 };",
            "    let food = { x: 5, y: 5 };",
            "    let score = 0;",
            "    let gameOver = false;",
            "",
            "    function placeFood() {",
            "      food = {",
            "        x: Math.floor(Math.random() * GRID),",
            "        y: Math.floor(Math.random() * GRID),",
            "      };",
            "    }",
            "",
            "    function tick() {",
            "      if (gameOver) return;",
            "      const head = {",
            "        x: snake[0].x + direction.x,",
            "        y: snake[0].y + direction.y,",
            "      };",
            "      const hitsWall = head.x < 0 || head.x >= GRID || head.y < 0 || head.y >= GRID;",
            "      const hitsSelf = snake.some((s) => s.x === head.x && s.y === head.y);",
            "      if (hitsWall || hitsSelf) {",
            "        gameOver = true;",
            "        overEl.style.display = 'flex';",
            "        return;",
            "      }",
            "      snake.unshift(head);",
            "      if (head.x === food.x && head.y === food.y) {",
            "        score++;",
            "        scoreEl.textContent = 'Score: ' + score;",
            "        placeFood();",
            "      } else {",
            "        snake.pop();",
            "      }",
            "      draw();",
            "    }",
            "",
            "    function draw() {",
            "      ctx.fillStyle = '#1a1a22';",
            "      ctx.fillRect(0, 0, canvas.width, canvas.height);",
            "      ctx.fillStyle = '#5b6ef5';",
            "      for (const segment of snake) {",
            "        ctx.fillRect(segment.x * CELL, segment.y * CELL, CELL - 2, CELL - 2);",
            "      }",
            "      ctx.fillStyle = '#4ade80';",
            "      ctx.fillRect(food.x * CELL, food.y * CELL, CELL - 2, CELL - 2);",
            "    }",
            "",
            "    document.addEventListener('keydown', (e) => {",
            "      const moves = {",
            "        ArrowUp: { x: 0, y: -1 },",
            "        ArrowDown: { x: 0, y: 1 },",
            "        ArrowLeft: { x: -1, y: 0 },",
            "        ArrowRight: { x: 1, y: 0 },",
            "      };",
            "      const next = moves[e.key];",
            "      if (!next) return;",
            "      if (next.x === -direction.x && next.y === -direction.y) return;",
            "      direction = next;",
            "    });",
            "",
            "    setInterval(tick, 110);",
            "    draw();",
            "  </script>",
            "</body>",
            "</html>",
            "```",
            "",
            "Use the arrow keys to move. The game runs on a 20×20 grid with 110ms tick interval — adjust either constant to tune difficulty."
          ]
        }
      }
